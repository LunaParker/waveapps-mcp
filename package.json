{
  "name": "waveapps-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Wave (waveapps.com) — drives invoices, customers, estimates, bills, and receipts via the internal Wave API.",
  "type": "module",
  "license": "MIT",
  "author": "Luna Parker <lunaparker33@gmail.com>",
  "private": true,
  "bin": {
    "waveapps-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "puppeteer-core": "^24.43.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.18.0"
  }
}
